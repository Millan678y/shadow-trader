# ═══════════════════════════════════════════════════
# SHADOW TRADER — Environment Variables
# Copy this to .env.local and fill in your values
# ═══════════════════════════════════════════════════

# ── Supabase (Database + Auth) ──────────────────
# Required for: user auth, trades, strategies, journal, portfolios
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI Research (Optional) ───────────────────────
# Groq provides free tier Llama-3.3 inference
# Get key: https://console.groq.com/keys
# The app works without this — AI responses use rule-based analysis
GROQ_API_KEY=gsk_your_key_here

# ── Market Data (Optional — defaults to free APIs) ─
# Binance public API: no key needed for market data
# For trading (order execution), get keys at: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ── Deployment ──────────────────────────────────
# Vercel: set these in Project Settings → Environment Variables
# Hostinger VPS: add to /etc/environment or use dotenv

# ── Feature Flags ───────────────────────────────
# Set to 'true' to enable experimental features
NEXT_PUBLIC_DRY_RUN_MODE=true